# PostgreSQL connection string. Supabase/Neon/Vercel Postgres work well.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Admin password for /admin. Change this before deploying.
ADMIN_PASSWORD="change-me-now"

# Random long secret. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-long-secret"

# Optional public settings
NEXT_PUBLIC_APP_URL="https://go.lippu.app"
NEXT_PUBLIC_BRAND_NAME="Lippu Go"

# Security: comma-separated allowed target domains.
# Use lippu.app,eventos.lippu.app,www.lippu.app to keep the shortener from being abused.
# Use "all" only if you intentionally want to allow any HTTPS destination.
ALLOWED_TARGET_HOSTS="lippu.app,eventos.lippu.app,www.lippu.app"
